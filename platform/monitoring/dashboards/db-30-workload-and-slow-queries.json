          "editorMode": "code",
          "expr": "topk(10, 100 * sum by (datname) (rate(pg_stat_database_blks_hit{datname!~\"template.*|postgres\"}[$__rate_interval])) / clamp_min(sum by (datname) (rate(pg_stat_database_blks_hit{datname!~\"template.*|postgres\"}[$__rate_interval]) + rate(pg_stat_database_blks_read{datname!~\"template.*|postgres\"}[$__rate_interval])), 0.001))",
          "legendFormat": "{{datname}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
