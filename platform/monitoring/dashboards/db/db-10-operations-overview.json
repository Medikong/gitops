          "editorMode": "code",
          "expr": "sum by (datname, mode) (pg_locks_count{namespace=~\"$db_namespace\",datname!~\"template.*|postgres\"})",
          "legendFormat": "lock {{datname}} {{mode}}",
          "range": true,
          "refId": "A"
