    {
      "id": 9,
      "title": "p95 / p99 DB Latency",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (service_name, db_system, le) (rate(db_client_operation_duration_seconds_bucket{service_environment=~\"$environment\",service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "p95 {{service_name}} {{db_system}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (service_name, db_system, le) (rate(db_client_operation_duration_seconds_bucket{service_environment=~\"$environment\",service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "p99 {{service_name}} {{db_system}}",
          "range": true,
          "refId": "B"
        }
