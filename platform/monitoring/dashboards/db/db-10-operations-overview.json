        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (datname) (increase(pg_stat_database_deadlocks{namespace=~\"$db_namespace\",datname!~\"template.*|postgres\"}[$__rate_interval]))",
