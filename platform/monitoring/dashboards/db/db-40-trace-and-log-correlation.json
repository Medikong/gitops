          "editorMode": "code",
          "expr": "{k8s_namespace_name=~\"$namespace\", service_name=\"$service\", k8s_container_name=~\".*-service\"} | json | event=\"db.query.slow\" | db_system=~\"$db_system\" | db_operation=~\"$db_operation\" | statement_fingerprint=~\"$fingerprint\" | line_format \"service={{.service_name}} db_system={{.db_system}} db_operation={{.db_operation}} fingerprint={{.statement_fingerprint}} normalized={{.normalized_statement}} duration_ms={{.duration_ms}} trace_id={{.trace_id}} request_id={{.request_id}}\"",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
