{
  "uid": "medikong-db-40-trace-and-log-correlation",
  "title": "DB 40 - Trace and Log Correlation",
  "tags": [
    "medikong",
    "database",
    "logs",
    "traces",
    "correlation"
  ],
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Service Namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(k8s_namespace_name)",
        "definition": "label_values(k8s_namespace_name)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": false,
          "text": "ticketing-payment",
          "value": "ticketing-payment"
        }
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({k8s_namespace_name=~\"$namespace\"}, service_name)",
        "definition": "label_values({k8s_namespace_name=~\"$namespace\"}, service_name)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": false,
          "text": "payment-service",
          "value": "payment-service"
        }
      },
      {
        "name": "db_system",
        "label": "DB System Regex",
        "type": "textbox",
        "query": "postgresql|mongodb",
        "current": {
          "selected": false,
          "text": "postgresql|mongodb",
          "value": "postgresql|mongodb"
        }
      },
      {
        "name": "db_operation",
        "label": "DB Operation Regex",
        "type": "textbox",
        "query": ".*",
        "current": {
          "selected": false,
          "text": ".*",
          "value": ".*"
        }
      },
      {
        "name": "fingerprint",
        "label": "Fingerprint Regex",
        "type": "textbox",
        "query": ".*",
        "current": {
          "selected": false,
          "text": ".*",
          "value": ".*"
        }
      },
      {
        "name": "request_id",
        "label": "Request ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      },
      {
        "name": "trace_id",
        "label": "Trace ID",
        "type": "textbox",
        "query": "__set_me__",
        "current": {
          "selected": false,
          "text": "__set_me__",
          "value": "__set_me__"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "1. Slow Operation Entry",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Slow Ops with Trace ID",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({k8s_namespace_name=~\"$namespace\", service_name=\"$service\", k8s_container_name=~\".*-service\"} | json | event=\"db.query.slow\" | db_system=~\"$db_system\" | db_operation=~\"$db_operation\" | statement_fingerprint=~\"$fingerprint\" | trace_id=~\"[a-fA-F0-9]{16,32}\" [30m]))",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
