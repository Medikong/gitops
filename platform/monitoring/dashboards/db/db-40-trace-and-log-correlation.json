          "editorMode": "code",
          "expr": "count(sum by (statement_fingerprint) (count_over_time({k8s_namespace_name=~\"$namespace\", service_name=\"$service\", k8s_container_name=~\".*-service\"} | json | event=\"db.query.slow\" | db_system=~\"$db_system\" | db_operation=~\"$db_operation\" | statement_fingerprint=~\"$fingerprint\" [30m])))",
          "range": true,
